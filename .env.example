# Google OAuth 2.0 Client ID
# https://console.cloud.google.com/apis/credentials で作成
VITE_GOOGLE_CLIENT_ID=

# OAuth リダイレクト URI (デフォルト: 現在のオリジン + /callback)
# VITE_REDIRECT_URI=http://localhost:5173/callback

# GitHub リポジトリ URL (設定画面のリンクに使用)
# VITE_GITHUB_URL=https://github.com/aftn/kakusu

# 公開サイト URL (プライバシーポリシー等のリンクに使用。未設定ならリンク非表示)
# VITE_PUBLIC_SITE_URL=https://example.com
